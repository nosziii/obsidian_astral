generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String                   @id @default(cuid())
  email              String?                  @unique
  passwordHash       String?
  role               String                   @default("jatekos")
  name               String
  bio                String                   @default("Új parancsnok az Obsidian Astral szektorban.")
  fleet              String                   @default("Nebulous Vanguard")
  level              Int                      @default(1)
  xp                 Int                      @default(0)
  energy             Int                      @default(100)
  energyMax          Int                      @default(100)
  credits            Int                      @default(250)
  astralite          Int                      @default(40)
  isSuspended        Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  inventory          InventoryEntry[]
  equipmentInventory EquipmentInventoryEntry[]
  equippedItems      EquippedItem[]
  buildings          BuildingState[]
  expeditions        ExpeditionRun[]
  chatMessages       ChatMessage[]
  notifications      Notification[]
  timedActions       TimedAction[]
  sessions           Session[]
}

model InventoryEntry {
  id          String   @id @default(cuid())
  playerId    String
  resourceKey String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, resourceKey])
}

model EquipmentInventoryEntry {
  id        String   @id @default(cuid())
  playerId  String
  itemKey   String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, itemKey])
}

model EquippedItem {
  id        String   @id @default(cuid())
  playerId  String
  slot      String
  itemKey   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, slot])
}

model BuildingState {
  id          String   @id @default(cuid())
  playerId    String
  buildingKey String
  level       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, buildingKey])
}

model ExpeditionRun {
  id            String   @id @default(cuid())
  playerId      String
  expeditionKey String
  status        String
  rewardPayload Json
  startedAt     DateTime
  endsAt        DateTime
  claimedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  playerId  String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  playerId   String?
  channel    String
  authorName String
  content    String
  createdAt  DateTime @default(now())
  player     Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([channel, createdAt])
}

model Notification {
  id           String   @id @default(cuid())
  playerId     String
  referenceKey String?
  kind         String
  title        String
  body         String
  tone         String
  actionLabel  String
  readAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([playerId, readAt, createdAt])
  @@unique([playerId, referenceKey])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorPlayerId String
  actorName    String
  targetPlayerId String
  targetName   String
  actionKind   String
  summary      String
  metadata     Json
  createdAt    DateTime @default(now())

  @@index([targetPlayerId, createdAt])
  @@index([actorPlayerId, createdAt])
}

model TimedAction {
  id        String   @id @default(cuid())
  playerId  String
  kind      String
  targetKey String
  status    String   @default("folyamatban")
  payload   Json
  startedAt DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, status, endsAt])
  @@index([playerId, kind, targetKey, status])
}
