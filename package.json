{
  "name": "obsidian-astral",
  "private": true,
  "version": "0.1.0",
  "description": "Obsidian Astral browser strategy RPG monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @obsidian-astral/api",
    "dev:web": "npm run dev --workspace @obsidian-astral/web",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm run build --workspace @obsidian-astral/shared",
    "build:api": "npm run build --workspace @obsidian-astral/api",
    "build:web": "npm run build --workspace @obsidian-astral/web",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:web",
    "typecheck:shared": "npm run typecheck --workspace @obsidian-astral/shared",
    "typecheck:api": "npm run typecheck --workspace @obsidian-astral/api",
    "typecheck:web": "npm run typecheck --workspace @obsidian-astral/web",
    "db:generate": "npm run prisma:generate --workspace @obsidian-astral/api",
    "db:push": "dotenv -e .env -- node scripts/run-prisma-command.mjs push",
    "db:seed": "dotenv -e .env -- node scripts/run-prisma-command.mjs seed"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "npm-run-all": "^4.1.5"
  }
}
