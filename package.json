{
  "name": "obsidian-astral",
  "private": true,
  "version": "0.1.0",
  "description": "Obsidian Astral browser strategy RPG monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @obsidian-astral/api",
    "dev:web": "npm run dev --workspace @obsidian-astral/web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "db:generate": "npm run prisma:generate --workspace @obsidian-astral/api",
    "db:push": "npm run prisma:push --workspace @obsidian-astral/api",
    "db:seed": "npm run prisma:seed --workspace @obsidian-astral/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
